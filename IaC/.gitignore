# Terraform state files (contain sensitive data)
*.tfstate
*.tfstate.*

# Variable files with secrets
*.tfvars
*.tfvars.json

# Provider plugins
.terraform/

# Lock file (optional - include if you want version pinning)
# .terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
