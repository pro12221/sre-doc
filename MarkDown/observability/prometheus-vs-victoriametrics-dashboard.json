{
  "uid": "prom-vm-bench",
  "title": "Prometheus vs VictoriaMetrics 压测对比",
  "tags": ["benchmark"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": []},
  "description": "Prometheus vs VictoriaMetrics 单机版压测对比仪表盘。数据源 uid=prom（监控 Prometheus）。配色：Prometheus=蓝，VictoriaMetrics=橙。",
  "panels": [
    {"id":1,"type":"row","title":"① 概览","gridPos":{"h":1,"w":24,"x":0,"y":0},"collapsed":false,"panels":[]},
    {"id":2,"type":"stat","title":"实例状态 (up)","gridPos":{"h":4,"w":4,"x":0,"y":1},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"up{job=\"prometheus-under-test\"}","legendFormat":"Prometheus"},{"refId":"B","expr":"up{job=\"victoriametrics-under-test\"}","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"UP","color":"green"},"0":{"text":"DOWN","color":"red"}}}]},"overrides":[]},"options":{"reduceOptions":{"calcs":["lastNotNull"]},"orientation":"horizontal"}},
    {"id":3,"type":"timeseries","title":"写入速率 (samples/s)","gridPos":{"h":8,"w":10,"x":4,"y":1},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"sum(rate(prometheus_tsdb_head_samples_appended_total{job=\"prometheus-under-test\"}[5m]))","legendFormat":"Prometheus"},{"refId":"B","expr":"sum(rate(vm_rows_inserted_total{job=\"victoriametrics-under-test\"}[5m]))","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"ops","custom":{"drawStyle":"line","lineInterpolation":"linear","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},
    {"id":4,"type":"timeseries","title":"Active Series","gridPos":{"h":8,"w":10,"x":14,"y":1},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"max(prometheus_tsdb_head_series{job=\"prometheus-under-test\"})","legendFormat":"Prometheus"},{"refId":"B","expr":"max(vm_cache_entries{job=\"victoriametrics-under-test\",type=~\"storage/.*\"})","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"short","custom":{"drawStyle":"line","lineInterpolation":"linear","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},

    {"id":5,"type":"row","title":"② 写入性能","gridPos":{"h":1,"w":24,"x":0,"y":9},"collapsed":false,"panels":[]},
    {"id":6,"type":"timeseries","title":"写入吞吐对比 (samples/s)","gridPos":{"h":8,"w":12,"x":0,"y":10},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"sum(rate(prometheus_tsdb_head_samples_appended_total{job=\"prometheus-under-test\"}[5m]))","legendFormat":"Prometheus"},{"refId":"B","expr":"sum(rate(vm_rows_inserted_total{job=\"victoriametrics-under-test\"}[5m]))","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"ops","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},
    {"id":7,"type":"timeseries","title":"写入丢弃/失败 (samples/s)","gridPos":{"h":8,"w":12,"x":12,"y":10},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"sum(rate(prometheus_target_scrapes_sample_out_of_order_total{job=\"prometheus-under-test\"}[5m])) + sum(rate(prometheus_target_scrapes_sample_out_of_bounds_total{job=\"prometheus-under-test\"}[5m]))","legendFormat":"Prometheus (out-of-order/bounds)"},{"refId":"B","expr":"sum(rate(vm_rows_ignored_total{job=\"victoriametrics-under-test\"}[5m])) + sum(rate(vm_rows_invalid_total{job=\"victoriametrics-under-test\"}[5m]))","legendFormat":"VictoriaMetrics (ignored/invalid)"}],"fieldConfig":{"defaults":{"unit":"ops","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus (out-of-order/bounds)"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics (ignored/invalid)"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},

    {"id":8,"type":"row","title":"③ 资源占用 (核心对比)","gridPos":{"h":1,"w":24,"x":0,"y":18},"collapsed":false,"panels":[]},
    {"id":9,"type":"timeseries","title":"进程内存 RSS","gridPos":{"h":8,"w":12,"x":0,"y":19},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"process_resident_memory_bytes{job=\"prometheus-under-test\"}","legendFormat":"Prometheus"},{"refId":"B","expr":"process_resident_memory_bytes{job=\"victoriametrics-under-test\"}","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"bytes","custom":{"drawStyle":"line","fillOpacity":10},"thresholds":{"mode":"absolute","steps":[{"color":"green"},{"color":"red","value":3670016000}]}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},
    {"id":10,"type":"timeseries","title":"进程 CPU (cores)","gridPos":{"h":8,"w":12,"x":12,"y":19},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"rate(process_cpu_seconds_total{job=\"prometheus-under-test\"}[5m])","legendFormat":"Prometheus"},{"refId":"B","expr":"rate(process_cpu_seconds_total{job=\"victoriametrics-under-test\"}[5m])","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"cores","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},
    {"id":11,"type":"timeseries","title":"磁盘占用","gridPos":{"h":8,"w":12,"x":0,"y":27},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"sum(prometheus_tsdb_storage_blocks_bytes{job=\"prometheus-under-test\"})","legendFormat":"Prometheus"},{"refId":"B","expr":"vm_data_size_bytes{job=\"victoriametrics-under-test\"}","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"bytes","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},
    {"id":12,"type":"timeseries","title":"压缩比 (bytes/sample)","gridPos":{"h":8,"w":12,"x":12,"y":27},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"sum(prometheus_tsdb_storage_blocks_bytes{job=\"prometheus-under-test\"}) / clamp_min(sum(prometheus_tsdb_head_samples_appended_total{job=\"prometheus-under-test\"}),1)","legendFormat":"Prometheus"},{"refId":"B","expr":"vm_data_size_bytes{job=\"victoriametrics-under-test\"} / clamp_max(vm_rows{job=\"victoriametrics-under-test\",type=\"metric\"},1)","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"bytes","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},

    {"id":13,"type":"row","title":"④ 查询性能 (vmalert 触发)","gridPos":{"h":1,"w":24,"x":0,"y":35},"collapsed":false,"panels":[]},
    {"id":14,"type":"timeseries","title":"查询延迟 p99","gridPos":{"h":8,"w":12,"x":0,"y":36},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"histogram_quantile(0.99, sum by (le) (rate(prometheus_http_request_duration_seconds_bucket{job=\"prometheus-under-test\",handler=~\"/api/v1/query.*\"}[5m])))","legendFormat":"Prometheus p99"},{"refId":"B","expr":"histogram_quantile(0.99, sum by (le) (rate(vm_http_request_duration_seconds_bucket{job=\"victoriametrics-under-test\",path=~\"/api/v1/query.*\"}[5m])))","legendFormat":"VictoriaMetrics p99"}],"fieldConfig":{"defaults":{"unit":"s","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus p99"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics p99"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},
    {"id":15,"type":"timeseries","title":"查询 QPS","gridPos":{"h":8,"w":12,"x":12,"y":36},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"sum(rate(prometheus_http_requests_total{job=\"prometheus-under-test\",handler=~\"/api/v1/query.*\"}[5m]))","legendFormat":"Prometheus"},{"refId":"B","expr":"sum(rate(vm_http_requests_total{job=\"victoriametrics-under-test\",path=~\"/api/v1/query.*\"}[5m]))","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"ops","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},

    {"id":16,"type":"row","title":"⑤ K8s 容器资源 (cAdvisor)","gridPos":{"h":1,"w":24,"x":0,"y":44},"collapsed":false,"panels":[]},
    {"id":17,"type":"timeseries","title":"容器内存 working set","gridPos":{"h":8,"w":12,"x":0,"y":45},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"container_memory_working_set_bytes{namespace=\"benchmark\",pod=\"prometheus-under-test-0\",container=\"prometheus\"}","legendFormat":"Prometheus"},{"refId":"B","expr":"container_memory_working_set_bytes{namespace=\"benchmark\",pod=\"victoriametrics-under-test-0\",container=\"victoria-metrics\"}","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"bytes","custom":{"drawStyle":"line","fillOpacity":10},"thresholds":{"mode":"absolute","steps":[{"color":"green"},{"color":"red","value":3670016000}]}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}},
    {"id":18,"type":"timeseries","title":"容器 CPU (cores)","gridPos":{"h":8,"w":12,"x":12,"y":45},"datasource":{"type":"prometheus","uid":"prom"},"targets":[{"refId":"A","expr":"rate(container_cpu_usage_seconds_total{namespace=\"benchmark\",pod=\"prometheus-under-test-0\",container=\"prometheus\"}[5m])","legendFormat":"Prometheus"},{"refId":"B","expr":"rate(container_cpu_usage_seconds_total{namespace=\"benchmark\",pod=\"victoriametrics-under-test-0\",container=\"victoria-metrics\"}[5m])","legendFormat":"VictoriaMetrics"}],"fieldConfig":{"defaults":{"unit":"cores","custom":{"drawStyle":"line","fillOpacity":10}},"overrides":[{"matcher":{"id":"byName","options":"Prometheus"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"blue"}}]},{"matcher":{"id":"byName","options":"VictoriaMetrics"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"orange"}}]}]}}
  ]
}
